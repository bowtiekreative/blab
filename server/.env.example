# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Auth
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# Allow the dev-only email login endpoint (never enable in production)
ALLOW_DEV_LOGIN=true

# Postgres
DATABASE_URL=postgres://localhost:5432/hustlezone

# CORS (frontend origin)
CORS_ORIGIN=http://localhost:5173

# LiveKit (Phase 3) — leave blank in early dev
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Stripe (Phase 5) — leave blank to run the economy in dev/simulated mode.
# When blank, token purchases are credited instantly and cash-outs are
# recorded without a real transfer (no money moves).
STRIPE_SECRET_KEY=
